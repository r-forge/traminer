  author = {Liao, Tim F. and Bolano, Danilo and {Brzinsky-Fay}, Christian and Cornwell, Benjamin and Fasang, Anette Eva and Helske, Satu and Piccarreta, Raffaella and Raab, Marcel and Ritschard, Gilbert and Struffolino, Emanuela and Studer, Matthias},
